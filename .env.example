# ═══════════════════════════════════════════════════════════════
# Poly Trade Bot — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── LLM Providers ──
OPENAI_API_KEY= 
GEMINI_API_KEY=
LLM_PROVIDER=openai

# ── Telegram Bot ──
TELEGRAM_TOKEN= 
TELEGRAM_CHAT_ID= 

# ── Polymarket Wallet (required for LIVE trading) ──
WALLET_PRIVATE_KEY=
POLY_PRIVATE_KEY=
POLY_PROXY_WALLET=
POLY_SIGNATURE_TYPE=0

# ── Weather API Keys (Open-Meteo is free & needs no key) ──
OPENWEATHERMAP_KEY= 

# ── Polygon RPC (optional, free public RPCs used as fallback) ──
POLYGON_RPC_URL=

# ── CLOB Relay (optional, for geo-blocked regions) ──
CLOB_RELAY_URL=

# ── Bot Mode ──
# PAPER = simulated trading, LIVE = real money
BOT_MODE=PAPER
STARTING_BALANCE=100
WEATHER_RISK_MODE=growth
